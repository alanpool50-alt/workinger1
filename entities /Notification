{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Recipient email"
    },
    "type": {
      "type": "string",
      "enum": [
        "application_viewed",
        "interview_invitation",
        "new_job_match",
        "message_received",
        "job_alert"
      ],
      "description": "Notification type"
    },
    "title": {
      "type": "string",
      "description": "Notification title"
    },
    "message": {
      "type": "string",
      "description": "Notification message"
    },
    "data": {
      "type": "object",
      "description": "Additional data (job_id, application_id, etc.)"
    },
    "read": {
      "type": "boolean",
      "default": false,
      "description": "Whether notification has been read"
    },
    "action_url": {
      "type": "string",
      "description": "URL to navigate when clicked"
    }
  },
  "required": [
    "user_email",
    "type",
    "title"
  ]
}

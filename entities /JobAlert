{
  "name": "JobAlert",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "User email"
    },
    "name": {
      "type": "string",
      "description": "Alert name"
    },
    "keywords": {
      "type": "string",
      "description": "Job keywords (Frontend, Designer, etc.)"
    },
    "location": {
      "type": "string",
      "description": "Desired location"
    },
    "is_remote": {
      "type": "boolean",
      "default": false
    },
    "job_type": {
      "type": "string",
      "enum": [
        "full_time",
        "part_time",
        "contract",
        "freelance",
        "internship",
        "any"
      ]
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "frequency": {
      "type": "string",
      "enum": [
        "instant",
        "daily",
        "weekly"
      ],
      "default": "daily"
    }
  },
  "required": [
    "user_email",
    "name"
  ]
}
